+		slices.Sort(want)
+		if slices.Equal(entry.Value().apiRootFiles, want) {
+			return true
+		}
+		if logger != nil {
+			logger.Logf("Updating API root files for project %s: %v", entry.Key(), want)
+		}
+		entry.Change(func(p *Project) {
