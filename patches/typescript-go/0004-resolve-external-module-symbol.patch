+// handleGetResolvedReferencesInFile walks a source file Go-side and resolves symbols at
+// every Identifier in one checker acquisition. Returns light symbol payloads plus
+// (endPosition → symbolId) entries for JS-side prefetch (one RPC per file vs ~30k).
+func (s *Session) handleGetResolvedReferencesInFile(ctx context.Context, params *GetResolvedReferencesInFileParams) (*GetResolvedReferencesInFileResponse, error) {
+	setup, err := s.setupChecker(ctx, params.Snapshot, params.Project)
+	if err != nil {
+		return nil, err
+	}
+	defer setup.done()
+
+	sourceFile := setup.program.GetSourceFile(params.File.ToFileName())
+	if sourceFile == nil {
+		return nil, fmt.Errorf("%w: source file not found: %v", ErrClientError, params.File)
+	}
+
+	positionMap := sourceFile.GetPositionMap()
+	refs := make([]ResolvedReferenceEntry, 0, 256)
+	lightByID := make(map[SymbolID]*LightSymbolResponse)
+
+	scope := params.Scope
+	if scope == "" {
+		scope = ResolvedReferencesScopeDeclarationNames
+	}
+	if scope != ResolvedReferencesScopeDeclarationNames && scope != ResolvedReferencesScopeIdentifiers && scope != ResolvedReferencesScopeAllIdentifiers {
+		return nil, fmt.Errorf("%w: unknown getResolvedReferencesInFile scope %q", ErrClientError, scope)
+	}
+
+	var visit func(*ast.Node) bool
+	visit = func(node *ast.Node) bool {
+		if node == nil {
+			return false
+		}
+		var shouldResolve bool
+		switch scope {
+		case ResolvedReferencesScopeAllIdentifiers:
+			shouldResolve = isAllIdentifiersPrefetchSite(node)
+		case ResolvedReferencesScopeIdentifiers:
+			shouldResolve = isNonMemberIdentifier(node)
+		case ResolvedReferencesScopeDeclarationNames:
+			shouldResolve = (ast.IsIdentifier(node) || node.Kind == ast.KindPrivateIdentifier) && ast.IsDeclarationNameOrImportPropertyName(node)
+		default:
+			return false
+		}
+		if shouldResolve {
+			symbol := setup.checker.GetSymbolAtLocation(node)
+			if symbol != nil {
+				light := setup.sd.newLightSymbolResponse(symbol)
+				if light != nil {
+					startUTF16 := positionMap.UTF8ToUTF16(node.Pos())
+					endUTF16 := positionMap.UTF8ToUTF16(node.End())
+					refs = append(refs, ResolvedReferenceEntry{
+						Start:    uint32(startUTF16),
+						Position: uint32(endUTF16),
+						SymbolId: light.Id,
+					})
+					if _, ok := lightByID[light.Id]; !ok {
+						lightByID[light.Id] = light
+					}
+				}
+			}
+		}
+		node.ForEachChild(visit)
+		return false
+	}
+	visit(sourceFile.AsNode())
+
+	symbols := make([]LightSymbolResponse, 0, len(lightByID))
+	for _, sym := range lightByID {
+		symbols = append(symbols, *sym)
+	}
+
+	return &GetResolvedReferencesInFileResponse{
+		References: refs,
+		Symbols:    symbols,
+	}, nil
+}
