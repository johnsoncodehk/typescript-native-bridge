+describe("Checker - resolveExternalModuleSymbol", () => {
+    test("resolves export= assignment target for CJS modules", () => {
+        const api = spawnAPI({
+            "/tsconfig.json": JSON.stringify({
+                compilerOptions: { strict: true, module: "commonjs" },
+            }),
+            "/src/mod.ts": `
+const impl = { foo: 1 };
+export = impl;
+`,
+        });
+        try {
+            const snapshot = api.updateSnapshot({ openProject: "/tsconfig.json" });
+            const project = snapshot.getProject("/tsconfig.json")!;
+            const sourceFile = project.program.getSourceFile("/src/mod.ts");
+            assert.ok(sourceFile);
+            const moduleSymbol = project.checker.getSymbolAtLocation(sourceFile);
+            assert.ok(moduleSymbol, "Source file should have a module symbol");
+            const resolved = project.checker.resolveExternalModuleSymbol(moduleSymbol);
+            assert.ok(resolved, "export= module should resolve to assignment target");
+            assert.notStrictEqual(resolved, moduleSymbol, "resolved symbol should differ from module container");
+            const type = project.checker.getTypeOfSymbol(resolved);
+            assert.ok(type, "resolved export= symbol should have a type");
+            const props = project.checker.getPropertiesOfType(type!);
+            assert.ok(props.some(p => p.name === "foo"), "export= value properties should be visible on resolved symbol type");
+        }
+        finally {
+            api.close();
+        }
+    });
+});
+
