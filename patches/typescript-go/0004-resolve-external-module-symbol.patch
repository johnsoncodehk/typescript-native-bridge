+	positionMap := sourceFile.GetPositionMap()
+	node := astnav.GetTouchingPropertyName(sourceFile, positionMap.UTF16ToUTF8(int(params.Position)))
+	if node == nil {
+		return nil, nil
+	}
+
+	t := setup.checker.GetTypeAtLocation(node)
+	if t == nil {
+		return nil, nil
+	}
