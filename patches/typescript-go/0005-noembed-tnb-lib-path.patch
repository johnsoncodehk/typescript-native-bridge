+// getenvLive reads the live process environment for keys set immediately
+// before dlopen (Node process.env.TNB_LIB_PATH = ...).
+//
+// Two channels are needed:
+//   - os.Getenv: on Windows this resolves through the Win32 environment block,
+//     which Node's process.env write (SetEnvironmentVariableW) updates. It is
+//     the ONLY channel that works there — the CRT environ that libc getenv
+//     reads is initialized at process start and never sees that write.
+//   - libc getenv: on POSIX, Go's os.Getenv reads the runtime-init snapshot and
+//     can miss a libc setenv issued right before koffi.load; libc getenv reads
+//     the live CRT environ instead.
+func getenvLive(key string) string {
+	if v := os.Getenv(key); v != "" {
+		return v
+	}
+	ckey := C.CString(key)
+	defer C.free(unsafe.Pointer(ckey))
+	cval := C.getenv(ckey)
+	if cval == nil {
+		return ""
+	}
+	return C.GoString(cval)
+}
+
 var libPath = sync.OnceValue(func() string {
 	if testing.Testing() {
 		return TestingLibPath()
 	}
+	// Prefer TNB_LIB_PATH when set (c-shared dylib loaded by node: os.Executable()
+	// is the node binary, not the dylib). Require lib.d.ts sentinel in that dir.
+	// Use libc getenv: JS sets the var via process.env immediately before koffi.load.
+	if env := getenvLive("TNB_LIB_PATH"); env != "" {
+		dir := tspath.NormalizeSlashes(env)
+		libdts := tspath.CombinePaths(dir, "lib.d.ts")
+		if info := osvfs.FS().Stat(libdts); info == nil {
