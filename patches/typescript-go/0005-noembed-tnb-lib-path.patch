+// getenvLive reads the process environ via libc so values set with setenv
+// immediately before dlopen (Node process.env.TNB_LIB_PATH = ...) are visible.
+// Go's os.Getenv may miss a key that was absent from the snapshot taken at
+// runtime init depending on how/when the key was introduced.
+func getenvLive(key string) string {
+	ckey := C.CString(key)
+	defer C.free(unsafe.Pointer(ckey))
+	cval := C.getenv(ckey)
+	if cval == nil {
+		return ""
+	}
+	return C.GoString(cval)
+}
+
 var libPath = sync.OnceValue(func() string {
 	if testing.Testing() {
 		return TestingLibPath()
 	}
+	// Prefer TNB_LIB_PATH when set (c-shared dylib loaded by node: os.Executable()
+	// is the node binary, not the dylib). Require lib.d.ts sentinel in that dir.
+	// Use libc getenv: JS sets the var via process.env immediately before koffi.load.
+	if env := getenvLive("TNB_LIB_PATH"); env != "" {
+		dir := tspath.NormalizeSlashes(env)
+		libdts := tspath.CombinePaths(dir, "lib.d.ts")
+		if info := osvfs.FS().Stat(libdts); info == nil {
+			panic(fmt.Sprintf("bundled: TNB_LIB_PATH=%v does not contain lib.d.ts (missing %v)", dir, libdts))
+		}
+		return dir
+	}
