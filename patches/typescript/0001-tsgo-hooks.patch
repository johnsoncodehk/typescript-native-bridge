+    const subpathExport = tryGetSubpathExportFromModuleFile(moduleFile);
+    if (subpathExport && isNpmPackageSpecifier(subpathExport)) {
+        precomputed.set(moduleSymbolId, subpathExport);
+        return subpathExport;
+    }
