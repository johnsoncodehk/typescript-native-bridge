+            importingFile,
+            defaultInfo.symbol,
+            defaultInfo.exportKind === ExportKind.Default ? InternalSymbolName.Default : InternalSymbolName.ExportEquals,
+            moduleSymbol,
+            moduleFile,
+            defaultInfo.exportKind,
+            isFromPackageJson,
+            checker,
+            /*precomputedTargetFlags*/ undefined,
+            moduleNameOverride,
+        );
+    }
+    checker.forEachExportAndPropertyOfModule(moduleSymbol, (exported, key) => {
+        if (exported !== defaultInfo?.symbol && isImportableSymbol(exported, checker) && addToSeen(seenExports, key)) {
+            cache.add(
+                importingFile,
+                exported,
+                key,
+                moduleSymbol,
+                moduleFile,
+                ExportKind.Named,
+                isFromPackageJson,
+                checker,
+                /*precomputedTargetFlags*/ undefined,
+                moduleNameOverride,
+            );
+        }
+    });
