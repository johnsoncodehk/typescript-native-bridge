+function tryGetPackageNameFromModuleFile(moduleFile: SourceFile, host: LanguageServiceHost): string | undefined {
+    let dir = getDirectoryPath(moduleFile.fileName);
+    while (dir) {
+        const packageJsonPath = combinePaths(dir, "package.json");
+        if (host.fileExists(packageJsonPath)) {
+            const content = host.readFile(packageJsonPath);
+            if (content) {
+                try {
+                    const parsed = JSON.parse(content);
+                    if (typeof parsed.name === "string" && isNpmPackageSpecifier(parsed.name)) {
+                        return parsed.name;
+                    }
+                }
+                catch {
+                    // ignore malformed package.json
+                }
+            }
+            return undefined;
+        }
+        const parent = getDirectoryPath(dir);
+        if (parent === dir) break;
+        dir = parent;
+    }
+    return undefined;
+}
