+    return undefined;
+}
+
+function tryGetSubpathExportFromModuleFile(moduleFile: SourceFile): string | undefined {
+    const normalized = moduleFile.fileName.replace(/\\/g, "/");
+    const nodeModules = "/node_modules/";
+    const lastNodeModules = normalized.lastIndexOf(nodeModules);
+    if (lastNodeModules < 0) return undefined;
+    const rest = normalized.substring(lastNodeModules + nodeModules.length);
+    const packageMatch = rest.match(/^((?:@[^/]+\/[^/]+|[^./@][^/]*))\/(.*)$/);
