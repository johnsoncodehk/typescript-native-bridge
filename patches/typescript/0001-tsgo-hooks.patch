+/** Stock walks project sources plus AutoImportProvider package.json deps; tsgo batch can omit them. */
+function supplementCheckerWalkExportInfoMap(
+    cache: ExportInfoMap,
+    importingFile: Path,
+    program: Program,
+    host: LanguageServiceHost,
+    preferences: UserPreferences,
+    cancellationToken: CancellationToken | undefined,
+    moduleCountRef: { count: number },
+    importingFileName: string,
+): void {
+    const importingSourceFile = program.getSourceFile(importingFileName);
+    const moduleSpecifierResolutionHost = importingSourceFile
+        ? createModuleSpecifierResolutionHost(program, host)
+        : undefined;
+    const moduleNameOverrideByModuleSymbolId = new Map<number, string>();
+    const moduleSymbolsForBatch: Symbol[] = [];
+    const pendingModules: {
+        moduleSymbol: Symbol;
+        moduleFile: SourceFile;
+        prog: Program;
+        isFromPackageJson: boolean;
+    }[] = [];
+
+    forEachExternalModuleToImportFrom(program, host, preferences, /*useAutoImportProvider*/ true, (moduleSymbol, moduleFile, prog, isFromPackageJson) => {
+        if (!moduleFile) return;
+        const fileName = moduleFile.fileName;
+        if (!pathContainsNodeModules(fileName)) {
+            pendingModules.push({ moduleSymbol, moduleFile, prog, isFromPackageJson });
+            return;
+        }
+        if (isFromPackageJson) {
+            pendingModules.push({ moduleSymbol, moduleFile, prog, isFromPackageJson });
+        }
+    }, /*includeMainProgram*/ false, importingFileName);
+
+    if (pendingModules.length && importingSourceFile) {
+        const getSpecifiersBatch = (program as Program & {
+            getModuleSpecifiersBatch?: (
+                importingFileName: string,
+                moduleSymbols: readonly Symbol[],
+                preferences: UserPreferences,
+            ) => { results: readonly { moduleSymbol: Symbol; moduleSpecifiers: readonly string[]; }[]; } | undefined;
+        }).getModuleSpecifiersBatch;
+        if (getSpecifiersBatch) {
+            for (const { moduleSymbol } of pendingModules) {
+                moduleSymbolsForBatch.push(moduleSymbol);
+            }
+            const specBatch = getSpecifiersBatch.call(program, importingFileName, moduleSymbolsForBatch, preferences);
+            for (const entry of specBatch?.results ?? []) {
+                const specifier = entry.moduleSpecifiers.find((s: string) => !isExternalModuleNameRelative(s) && isNpmPackageSpecifier(s));
+                if (specifier) {
+                    moduleNameOverrideByModuleSymbolId.set(getSymbolId(entry.moduleSymbol), specifier);
+                }
+            }
+        }
+    }
+
+    for (const { moduleSymbol, moduleFile, prog, isFromPackageJson } of pendingModules) {
+        const moduleNameOverride = resolveSupplementModuleNameOverride(
+            importingFileName,
+            importingSourceFile,
+            moduleSymbol,
+            moduleFile,
+            isFromPackageJson,
+            program,
+            prog,
+            host,
+            preferences,
+            moduleNameOverrideByModuleSymbolId,
+        );
+        if (isFromPackageJson && moduleNameOverride) {
+            const overrideSpecifier = stripQuotes(moduleNameOverride);
+            const pkgRoot = getNpmPackageRootFromSpecifier(overrideSpecifier);
+            const isSubpathOverride = !!(pkgRoot && overrideSpecifier !== pkgRoot);
+            if (isSubpathOverride && pkgRoot && supplementModuleExportsAlreadyCovered(
+                cache,
+                importingFile,
+                moduleSymbol,
+                prog,
+                pkgRoot,
+                /*matchExistingRootEntry*/ true,
+            )) {
+                continue;
+            }
+        }
+        addExportInfoForModule(
+            cache,
+            importingFile,
+            moduleSymbol,
+            moduleFile,
+            isFromPackageJson,
+            prog,
+            cancellationToken,
+            moduleCountRef,
+            moduleNameOverride,
+        );
+    }
+}
+
+function resolveSupplementModuleNameOverride(
+    importingFileName: string,
+    importingSourceFile: SourceFile | undefined,
+    moduleSymbol: Symbol,
+    moduleFile: SourceFile,
+    isFromPackageJson: boolean,
+    mainProgram: Program,
+    providerProgram: Program,
+    host: LanguageServiceHost,
+    preferences: UserPreferences,
+    precomputed: Map<number, string>,
+): string | undefined {
+    const moduleSymbolId = getSymbolId(moduleSymbol);
+    const cached = precomputed.get(moduleSymbolId);
+    if (cached) return cached;
+
+    const isProjectSource = !pathContainsNodeModules(moduleFile.fileName);
+    if (importingSourceFile) {
+        const resolutionHost = createModuleSpecifierResolutionHost(
+            isFromPackageJson ? providerProgram : mainProgram,
+            host,
+        );
+        const specResult = moduleSpecifiers.getModuleSpecifiersWithCacheInfo(
+            moduleSymbol,
+            providerProgram.getTypeChecker(),
+            mainProgram.getCompilerOptions(),
+            importingSourceFile,
+            resolutionHost,
+            preferences,
+            /*options*/ undefined,
+            /*forAutoImport*/ true,
+        );
+        const specifier = specResult?.moduleSpecifiers?.find((s: string) => !isExternalModuleNameRelative(s) && isNpmPackageSpecifier(s));
