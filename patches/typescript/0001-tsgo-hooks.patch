+
+function supplementModuleExportsAlreadyCovered(
+    cache: ExportInfoMap,
+    importingFile: Path,
+    moduleSymbol: Symbol,
+    program: Program,
+    pkgRoot?: string,
+    matchExistingRootEntry?: boolean,
+): boolean {
+    const checker = program.getTypeChecker();
+    const seenExports = new Set<__String>();
