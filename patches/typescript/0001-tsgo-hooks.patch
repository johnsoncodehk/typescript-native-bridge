+    if (subpath.endsWith(".d.ts")) subpath = subpath.slice(0, -".d.ts".length);
+    else if (subpath.endsWith(".ts")) subpath = subpath.slice(0, -".ts".length);
+    else if (subpath.endsWith(".js")) subpath = subpath.slice(0, -".js".length);
+    return subpath ? `${packageName}/${subpath}` : packageName;
